# LLM
MOONSHOT_API_KEY=replace-me
LLM_MODEL=kimi-k2.6
LLM_TEMPERATURE=1.0
LLM_MAX_TOKENS=800
FIRST_TOKEN_WAIT_SECONDS=10
FIRST_TOKEN_TIMEOUT_SECONDS=30
STREAM_IDLE_TIMEOUT_SECONDS=20
ORPHAN_REQUEST_TIMEOUT_SECONDS=120

# Retrieval
EMBEDDING_MODEL_PATH=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=4
RAG_CANDIDATE_K=80

# Redis exact cache
REDIS_URL=redis://127.0.0.1:6379/0
EXACT_CACHE_TTL_SECONDS=86400

# MySQL
MYSQL_ROOT_PASSWORD=replace-me
MYSQL_DATABASE=rag_app
MYSQL_USER=rag_user
MYSQL_PASSWORD=replace-me
DATABASE_URL=mysql+pymysql://rag_user:replace-me@127.0.0.1:3306/rag_app
DATABASE_CONNECT_TIMEOUT=5
